# TMDB API key (required for search and metadata)
VITE_TMDB_API_KEY=

# UI language for TMDB results (e.g. en, fr, de)
VITE_LANGUAGE=en

# Local link downloader service
VITE_DOWNLOADER_URL=http://localhost:3001
VITE_DOWNLOADER_TOKEN=

# Folder keys passed to the downloader service
VITE_MOVIE_FOLDER_KEY=movies
VITE_TV_FOLDER_KEY=tv

# Jellyfin integration (optional)
VITE_JELLYFIN_URL=
VITE_JELLYFIN_API_KEY=

# Jackett integration (optional) — enables searching across all configured Jackett indexers
VITE_JACKETT_URL=http://localhost:9117
VITE_JACKETT_API_KEY=
